{
  "name": "svelte-loading-indicator",
  "version": "0.0.1",
  "description": "A SvelteKit top loading progress bar component, feature-parity port of nextjs-toploader, built with Svelte 5 runes.",
  "type": "module",
  "license": "MIT",
  "author": "Ketarketir",
  "keywords": [
    "sveltekit",
    "svelte",
    "svelte5",
    "runes",
    "toploader",
    "top-loader",
    "progress-bar",
    "nprogress",
    "nextjs-toploader",
    "loading-bar",
    "page-loading-indicator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ketarketir/svelte-loading-indicator.git"
  },
  "homepage": "https://github.com/ketarketir/svelte-loading-indicator#readme",
  "bugs": {
    "url": "https://github.com/ketarketir/svelte-loading-indicator/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "npm run prepack",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.21",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.14.0"
}